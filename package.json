{
  "name": "battlecaos-room",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:integration": "node scripts/test-integracion.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "ioredis": "^5.5.0",
    "kafkajs": "^2.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "nodemon": "^3.1.14",
    "vitest": "^4.1.9"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "include": [
        "src/domain/**"
      ],
      "reporter": [
        "text",
        "html"
      ]
    }
  }
}
